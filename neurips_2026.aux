\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Stimulation Protocols and Network Configurations.} Schematic representation of the classical receptive field (CRF) and extra-classical receptive field (eCRF) paradigms across the three evaluated architectures. The bottom panels illustrate the thalamic stimulation over time and the corresponding peri-stimulus time histograms (PSTH) for Layer 2/3 neurons in V1, highlighting the varying degrees of surround suppression.}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:protocol}{{2}{6}{\textbf {Stimulation Protocols and Network Configurations.} Schematic representation of the classical receptive field (CRF) and extra-classical receptive field (eCRF) paradigms across the three evaluated architectures. The bottom panels illustrate the thalamic stimulation over time and the corresponding peri-stimulus time histograms (PSTH) for Layer 2/3 neurons in V1, highlighting the varying degrees of surround suppression}{figure.2}{}}
