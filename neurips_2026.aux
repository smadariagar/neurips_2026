\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Canonical Microcircuit and Hierarchical Architecture.} (Left) Local and intra-areal connectivity of the V1 microcircuit, detailing the specific interlaminar excitatory (E) and inhibitory (I) projections. (Right) Inter-areal feedforward and feedback connectivity between V1 and V2, along with near and distant lateral connections within V1.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:architectures}{{1}{4}{\textbf {Canonical Microcircuit and Hierarchical Architecture.} (Left) Local and intra-areal connectivity of the V1 microcircuit, detailing the specific interlaminar excitatory (E) and inhibitory (I) projections. (Right) Inter-areal feedforward and feedback connectivity between V1 and V2, along with near and distant lateral connections within V1}{figure.1}{}}
