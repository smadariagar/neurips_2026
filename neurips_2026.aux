\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Detailed activity profile for the competitive V2 architecture (Config. 3).} Mean firing rates (in spikes/s $\pm $ SD) of excitatory neurons in the central V1 column and the central V2 module under CRF and eCRF stimulation with a 30 Hz peripheral stimulus. This configuration shows deep suppression in both V1 and V2 superficial layers, driven by hierarchical competition. }}{8}{table.2}\protected@file@percent }
\newlabel{tab:detailed_activity}{{2}{8}{\textbf {Detailed activity profile for the competitive V2 architecture (Config. 3).} Mean firing rates (in spikes/s $\pm $ SD) of excitatory neurons in the central V1 column and the central V2 module under CRF and eCRF stimulation with a 30 Hz peripheral stimulus. This configuration shows deep suppression in both V1 and V2 superficial layers, driven by hierarchical competition}{table.2}{}}
