\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Quantification of extra-classical surround suppression across architectures.} Normalized activity in L2/3 of the central V1 column during the eCRF protocol (center 20 Hz, surround 30 Hz), expressed as a percentage of the peak CRF response. Values closer to 0\% indicate stronger suppression. The competitive V2 model (Config. 3) is the only architecture that quantitatively reproduces the $\sim $75\% suppression (i.e., $\sim $25\% residual activity) observed \textit  {in vivo} \citep  {Busse2009}. }}{7}{table.1}\protected@file@percent }
\newlabel{tab:suppression_summary}{{1}{7}{\textbf {Quantification of extra-classical surround suppression across architectures.} Normalized activity in L2/3 of the central V1 column during the eCRF protocol (center 20 Hz, surround 30 Hz), expressed as a percentage of the peak CRF response. Values closer to 0\% indicate stronger suppression. The competitive V2 model (Config. 3) is the only architecture that quantitatively reproduces the $\sim $75\% suppression (i.e., $\sim $25\% residual activity) observed \textit {in vivo} \citep {Busse2009}}{table.1}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Surround Suppression is Driven by Hierarchical Competition.} (A) Diagram of the V1-V2 competitive architecture illustrating the lateral inhibitory (IL) connections. (B) Mean firing rates across V1, V2, and thalamic populations during CRF and eCRF stimulation. Only the architecture incorporating competitive lateral inhibition in V2 replicates the profound ($\sim $75\%) suppression observed \textit  {in vivo} within V1 Layer 2/3. Statistical significance is denoted by *** ($p < 0.001$).}}{7}{figure.3}\protected@file@percent }
\newlabel{fig:results}{{3}{7}{\textbf {Surround Suppression is Driven by Hierarchical Competition.} (A) Diagram of the V1-V2 competitive architecture illustrating the lateral inhibitory (IL) connections. (B) Mean firing rates across V1, V2, and thalamic populations during CRF and eCRF stimulation. Only the architecture incorporating competitive lateral inhibition in V2 replicates the profound ($\sim $75\%) suppression observed \textit {in vivo} within V1 Layer 2/3. Statistical significance is denoted by *** ($p < 0.001$)}{figure.3}{}}
\newlabel{sec:results_wta}{{4}{7}{Results}{figure.3}{}}
